# ─────────────────────────────────────────────────────────────
# Hardware POS — root environment example
# Copy to `.env` and fill in values. Never commit `.env`.
# Package-specific examples live in apps/*/.env.example and
# packages/*/.env.example.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# PostgreSQL connection string (shared by API and Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hardware_pos?schema=public"

# Backend API
API_PORT=4000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── QuickBooks Online (placeholders — integration not implemented yet) ──
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:4000/quickbooks/callback
QBO_ENVIRONMENT=sandbox
