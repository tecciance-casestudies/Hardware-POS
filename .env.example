# ─────────────────────────────────────────────────────────────
# Hardware POS — root environment example
# Copy to `.env` and fill in values. Never commit `.env`.
# Package-specific examples live in apps/*/.env.example and
# packages/*/.env.example.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# PostgreSQL connection string (shared by API and Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hardware_pos?schema=public"

# Backend API
API_PORT=4000

# Auth — secret used to sign session JWTs (required). Use a long random value.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── QuickBooks Online OAuth 2.0 ──
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:4000/v1/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# Key used to encrypt stored OAuth tokens at rest (required for QuickBooks).
TOKEN_ENCRYPTION_KEY=change-me-32-byte-random-secret
