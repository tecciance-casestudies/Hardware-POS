auto-install-peers=true
strict-peer-dependencies=false

# Install a flat, npm-style node_modules instead of pnpm's symlinked layout.
# Required for AWS Amplify Next.js SSR deploys: Amplify's compute bundler does
# not follow pnpm's symlinks into the .pnpm store, so without this it fails with
# "The 'node_modules' folder is missing the 'next' dependency".
# https://github.com/aws-amplify/amplify-hosting/blob/main/FAQ.md
node-linker=hoisted
