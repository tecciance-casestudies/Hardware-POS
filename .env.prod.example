# Hardware POS — production env for docker-compose.prod.yml.
# Copy to .env.prod on the EC2 host and fill in real secrets. NEVER commit .env.prod.
#   cp .env.prod.example .env.prod
#
# Every value here is injected straight into the containers (no interpolation).

NODE_ENV=production
API_PORT=4000

# ── Database ──
# Keep POSTGRES_USER=postgres and POSTGRES_DB=hardware_pos (the compose
# healthcheck expects them). Set a strong password, and use THE SAME password
# in DATABASE_URL below. Host is "db" — the compose service name, not localhost.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_long_random
POSTGRES_DB=hardware_pos
DATABASE_URL="postgresql://postgres:CHANGE_ME_long_random@db:5432/hardware_pos?schema=public"

# ── CORS: the Amplify frontend origin ──
# Single origin. Point it at the domain the app is actually served from. If you
# use both apex and www, set Amplify to redirect www -> apex and use the apex here.
WEB_ORIGIN=https://axlopos.com

# ── Auth ──
JWT_SECRET=CHANGE_ME_long_random_64_chars
JWT_EXPIRES_IN=12h

# Encrypts stored QuickBooks OAuth tokens at rest (required). 32-byte random.
TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_byte_random_secret

# ── Uploads ──
# 'local' writes to UPLOAD_DIR (a mounted volume, set by compose). For durability
# across instance replacement, switch to S3 and fill the block below instead.
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3
# S3_BUCKET=hardware-pos-uploads
# S3_REGION=eu-north-1
# (Real AWS S3: omit S3_ENDPOINT and use an IAM role or access keys.)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ── QuickBooks Online OAuth ──
# The redirect URI must be HTTPS + public, and must ALSO be registered verbatim
# in the Intuit developer console.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://api.axlopos.com/v1/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=production

# ── Public share links (quotations) ──
PUBLIC_SHARE_BASE_URL=https://api.axlopos.com/v1

# ── Email ──
MAIL_PROVIDER=log
MAIL_FROM=Hardware POS <no-reply@axlopos.com>
# Resend:
# MAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxx
# SMTP:
# MAIL_PROVIDER=smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
