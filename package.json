{
  "name": "hardware-pos",
  "version": "0.1.0",
  "private": true,
  "description": "Hardware POS — a cashier sales front-end that syncs with QuickBooks Online (inventory & accounting source of truth).",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@hardware-pos/web",
    "dev:api": "turbo run dev --filter=@hardware-pos/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @hardware-pos/database db:generate",
    "db:migrate": "pnpm --filter @hardware-pos/database db:migrate",
    "db:seed": "pnpm --filter @hardware-pos/database db:seed",
    "db:studio": "pnpm --filter @hardware-pos/database db:studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
