{
  "name": "@hardware-pos/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types, enums, and constants used across the Hardware POS web and API apps.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(no linter configured for @hardware-pos/shared yet)\"",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
