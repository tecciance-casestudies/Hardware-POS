// Hardware POS — Prisma schema
//
// QuickBooks Online is the product / inventory / accounting master. This
// database holds the POS's local operational data plus a cached copy of
// QuickBooks products for fast checkout. The POS never edits stock or prices
// in QuickBooks directly — inventory changes as a side effect of the Sales
// Receipts / Invoices it pushes.
//
// Money is stored as Decimal(12, 2); quantities as Decimal(12, 3).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum UserRole {
  CASHIER
  MANAGER
  ADMIN
  OWNER
  ACCOUNTANT
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  QR_PAYMENT
  CHECK
  STORE_CREDIT
  OTHER
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum SyncStatus {
  NOT_SYNCED
  PENDING
  SYNCING
  SYNCED
  FAILED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum CustomerType {
  WALK_IN
  RETAIL
  CONTRACTOR
  CREDIT
  DEALER
}

enum QuickBooksDocumentType {
  SALES_RECEIPT
  INVOICE
}

enum SaleStatus {
  DRAFT
  COMPLETED
  VOIDED
  REFUNDED
}

enum PrintJobType {
  CUSTOMER_RECEIPT
  WAREHOUSE_PICKING
  RETURN_RECEIPT
}

enum PrintJobStatus {
  PENDING
  PRINTED
  FAILED
}

// ─────────────────────────────────────────────────────────────
// Returns / refunds
// ─────────────────────────────────────────────────────────────

// Lifecycle of a return document.
enum ReturnStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  COMPLETED
  CANCELLED
  FAILED
}

// Whether the money has actually left the drawer / been credited.
enum RefundStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ReturnReason {
  WRONG_PRODUCT
  DAMAGED
  DEFECTIVE
  EXTRA_QUANTITY
  CHANGED_MIND
  NOT_SUITABLE
  OTHER
}

enum ItemCondition {
  GOOD
  DAMAGED
  DEFECTIVE
  OPENED_USED
  NON_RESELLABLE
}

// What the POS asks QuickBooks to do with the physical stock.
enum StockDisposition {
  RETURN_TO_STOCK
  DAMAGED_STOCK
  SUPPLIER_REVIEW
  DO_NOT_RESTOCK
}

// Per-sale / per-line rollup of how much has been returned.
enum SaleReturnStatus {
  NOT_RETURNED
  PARTIALLY_RETURNED
  FULLY_RETURNED
}

// QuickBooks document a return maps to. Paid-sale refunds become Refund
// Receipts; credit / invoice returns become Credit Memos. Configurable per
// tenant — do not assume a single workflow.
enum QuickBooksReturnDocumentType {
  REFUND_RECEIPT
  CREDIT_MEMO
}

// ─────────────────────────────────────────────────────────────
// Quotations
// ─────────────────────────────────────────────────────────────

// Lifecycle of a quotation. A quotation is a non-binding priced offer; it is
// NOT a sale until explicitly converted. Editing a DRAFT mutates its current
// revision in place; issuing a change after it has been sent creates a new
// immutable revision (R1, R2, …) so history is preserved.
enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  REVISED
  CONVERTED_TO_SALE
  CANCELLED
}

// How a quotation document was delivered to the customer.
enum ShareChannel {
  WHATSAPP
  EMAIL
  DOWNLOAD
  PRINT
}

enum ShareStatus {
  PENDING
  SENT
  FAILED
}

// ─────────────────────────────────────────────────────────────
// Tenancy & locations
// ─────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches             Branch[]
  registers            Register[]
  users                User[]
  roles                Role[]
  categories           ProductCategory[]
  products             Product[]
  customers            Customer[]
  sales                Sale[]
  payments             Payment[]
  discounts            Discount[]
  syncJobs             SyncJob[]
  syncLogs             SyncLog[]
  quickbooksConnection QuickBooksConnection?
  quickbooksMappings   QuickBooksMapping[]
  auditLogs            AuditLog[]
  printJobs            PrintJob[]
  returns              Return[]
  refundPayments       RefundPayment[]
  subcategories        ProductSubcategory[]
  quotations           Quotation[]
  quotationShareLogs   QuotationShareLog[]
  refreshTokens        RefreshToken[]
  settings             TenantSettings[]
}

/**
 * Persisted per-tenant application settings (currency/tax/returns/quotation
 * defaults, document letterhead & template toggles, sharing templates). Stored
 * as a single merged JSON document keyed by tenant (and optionally branch) so
 * the settings shape can evolve without a migration per field; the settings
 * service merges this over code defaults. `branchId = null` is the tenant-wide
 * profile; a row with a branchId is a branch-level override (future use).
 */
model TenantSettings {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId])
  @@index([tenantId])
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registers  Register[]
  users      User[]
  sales      Sale[]
  returns    Return[]
  quotations Quotation[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Register {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String
  name      String
  code      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sales   Sale[]
  returns Return[]

  @@unique([branchId, code])
  @@index([tenantId])
  @@index([branchId])
}

// ─────────────────────────────────────────────────────────────
// Access control
// ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  tenantId     String
  branchId     String?
  roleId       String?
  role         UserRole  @default(CASHIER)
  name         String
  email        String?
  passwordHash String?
  pinHash      String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch             Branch?             @relation(fields: [branchId], references: [id])
  customRole         Role?               @relation(fields: [roleId], references: [id])
  sales              Sale[]
  payments           Payment[]
  approvedDiscounts  SaleItem[]          @relation("DiscountApprover")
  auditLogs          AuditLog[]
  returnsCreated     Return[]            @relation("ReturnCreatedBy")
  returnsApproved    Return[]            @relation("ReturnApprovedBy")
  refundPayments     RefundPayment[]
  quotationsCreated  Quotation[]         @relation("QuotationCreatedBy")
  quotationRevisions QuotationRevision[] @relation("QuotationRevisionChangedBy")
  quotationShares    QuotationShareLog[] @relation("QuotationShareSentBy")
  refreshTokens      RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([branchId])
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  permissions Permission[] @relation("RolePermissions")

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles Role[] @relation("RolePermissions")
}

/// Long-lived, rotating session tokens. Only the SHA-256 hash is stored; a
/// row is dead once `revokedAt` is set or `expiresAt` has passed.
model RefreshToken {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// Catalog (cached from QuickBooks)
// ─────────────────────────────────────────────────────────────

model ProductCategory {
  id               String   @id @default(cuid())
  tenantId         String
  quickbooksItemId String?
  name             String
  slug             String?
  description      String?
  imageUrl         String?
  parentId         String?
  // Manual ordering for the POS category tabs / management list.
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent        ProductCategory?     @relation("CategoryTree", fields: [parentId], references: [id])
  children      ProductCategory[]    @relation("CategoryTree")
  subcategories ProductSubcategory[]
  products      Product[]

  @@index([tenantId])
  @@index([parentId])
}

// A second, explicit level of the catalog hierarchy. A product may reference a
// category and (optionally) one of that category's subcategories. Kept separate
// from the legacy self-referential `parentId` tree, which QuickBooks sync writes
// flat and which no code consumes.
model ProductSubcategory {
  id          String   @id @default(cuid())
  tenantId    String
  categoryId  String
  name        String
  slug        String?
  description String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([categoryId, name])
  @@index([tenantId])
  @@index([categoryId])
}

/// Mirrors the QuickBooks Products & Services item fields (import template):
/// name, category, item type, SKU, sales description/price, purchase
/// description/cost, the three account names, quantity on hand + as-of date,
/// and reorder point. `isActive` and the sync columns are system fields
/// (QBO items have active status too; soft-delete keeps sale history intact).
model Product {
  id               String     @id @default(cuid())
  tenantId         String
  quickbooksItemId String?
  name             String
  /// QuickBooks item type: Inventory | NonInventory | Service.
  type             String     @default("Inventory")
  sku              String?
  /// Sales description — appears on sales forms and receipts.
  description      String?
  categoryId       String?
  subcategoryId    String?
  unitPrice        Decimal    @default(0) @db.Decimal(12, 2)
  /// QBO income account name (auto-resolved on sync; read-only in the UI).
  incomeAccount    String?
  /// Purchase description — what vendors see on purchase forms.
  purchaseDescription String?
  costPrice        Decimal?   @db.Decimal(12, 2)
  /// QBO expense account name (auto-resolved on sync; read-only in the UI).
  expenseAccount   String?
  quantityOnHand   Decimal    @default(0) @db.Decimal(12, 3)
  /// The date the quantity on hand was counted (QBO InvStartDate).
  quantityAsOfDate DateTime?
  reorderLevel     Decimal?   @db.Decimal(12, 3)
  /// QBO inventory asset account name (auto-resolved; read-only in the UI).
  inventoryAssetAccount String?
  /// POS-side product photo (S3/LocalStack) — never pushed to QuickBooks.
  imageUrl         String?
  isActive         Boolean    @default(true)
  lastSyncedAt     DateTime?
  syncStatus       SyncStatus @default(NOT_SYNCED)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       ProductCategory?    @relation(fields: [categoryId], references: [id])
  subcategory    ProductSubcategory? @relation(fields: [subcategoryId], references: [id])
  saleItems      SaleItem[]
  returnItems    ReturnItem[]
  quotationItems QuotationItem[]

  @@unique([tenantId, quickbooksItemId])
  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([categoryId])
  @@index([subcategoryId])
}

// ─────────────────────────────────────────────────────────────
// Customers (cached from QuickBooks)
// ─────────────────────────────────────────────────────────────

model Customer {
  id                   String       @id @default(cuid())
  tenantId             String
  quickbooksCustomerId String?
  name                 String
  companyName          String?
  customerType         CustomerType @default(RETAIL)
  email                String?
  phone                String?
  billingAddress       String?
  taxNumber            String?
  creditAllowed        Boolean      @default(false)
  creditLimit          Decimal?     @db.Decimal(12, 2)
  notes                String?
  isActive             Boolean      @default(true)
  lastSyncedAt         DateTime?
  syncStatus           SyncStatus   @default(NOT_SYNCED)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales      Sale[]
  returns    Return[]
  quotations Quotation[]

  @@unique([tenantId, quickbooksCustomerId])
  @@index([tenantId])
  @@index([tenantId, name])
}

// ─────────────────────────────────────────────────────────────
// Sales
// ─────────────────────────────────────────────────────────────

model Sale {
  id                        String                  @id @default(cuid())
  tenantId                  String
  branchId                  String
  registerId                String?
  cashierId                 String
  customerId                String?
  saleNumber                String
  status                    SaleStatus              @default(DRAFT)
  subtotal                  Decimal                 @default(0) @db.Decimal(12, 2)
  totalDiscount             Decimal                 @default(0) @db.Decimal(12, 2)
  orderDiscountType         DiscountType?
  orderDiscountValue        Decimal?                @db.Decimal(12, 2)
  orderDiscountAmount       Decimal                 @default(0) @db.Decimal(12, 2)
  orderDiscountReason       String?
  orderDiscountApprovedById String?
  taxAmount                 Decimal                 @default(0) @db.Decimal(12, 2)
  total                     Decimal                 @default(0) @db.Decimal(12, 2)
  paidAmount                Decimal                 @default(0) @db.Decimal(12, 2)
  balanceAmount             Decimal                 @default(0) @db.Decimal(12, 2)
  paymentStatus             PaymentStatus           @default(UNPAID)
  returnStatus              SaleReturnStatus        @default(NOT_RETURNED)
  returnedAmount            Decimal                 @default(0) @db.Decimal(12, 2)
  quickbooksDocumentType    QuickBooksDocumentType?
  quickbooksDocumentId      String?
  syncStatus                SyncStatus              @default(NOT_SYNCED)
  syncError                 String?
  completedAt               DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch     @relation(fields: [branchId], references: [id])
  register  Register?  @relation(fields: [registerId], references: [id])
  cashier   User       @relation(fields: [cashierId], references: [id])
  customer  Customer?  @relation(fields: [customerId], references: [id])
  items     SaleItem[]
  payments  Payment[]
  receipt   Receipt?
  printJobs PrintJob[]
  returns   Return[]
  quotation Quotation? @relation("QuotationConvertedSale")

  @@unique([tenantId, saleNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([cashierId])
  @@index([customerId])
  @@index([syncStatus])
  @@index([createdAt])
}

model SaleItem {
  id               String           @id @default(cuid())
  saleId           String
  productId        String
  productName      String
  sku              String?
  unitPrice        Decimal          @db.Decimal(12, 2)
  quantity         Decimal          @db.Decimal(12, 3)
  discountId       String?
  discountType     DiscountType?
  discountValue    Decimal?         @db.Decimal(12, 2)
  discountAmount   Decimal          @default(0) @db.Decimal(12, 2)
  discountReason   String?
  approvedByUserId String?
  taxAmount        Decimal          @default(0) @db.Decimal(12, 2)
  lineSubtotal     Decimal          @db.Decimal(12, 2)
  lineTotal        Decimal          @db.Decimal(12, 2)
  returnedQuantity Decimal          @default(0) @db.Decimal(12, 3)
  returnStatus     SaleReturnStatus @default(NOT_RETURNED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  sale        Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  discount    Discount?    @relation(fields: [discountId], references: [id])
  approvedBy  User?        @relation("DiscountApprover", fields: [approvedByUserId], references: [id])
  returnItems ReturnItem[]

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id                  String        @id @default(cuid())
  tenantId            String
  saleId              String
  receivedByUserId    String?
  amount              Decimal       @db.Decimal(12, 2)
  method              PaymentMethod
  reference           String?
  quickbooksPaymentId String?
  syncStatus          SyncStatus    @default(NOT_SYNCED)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale       Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  receivedBy User?  @relation(fields: [receivedByUserId], references: [id])

  @@index([tenantId])
  @@index([saleId])
  @@index([syncStatus])
}

model Discount {
  id                String       @id @default(cuid())
  tenantId          String
  name              String
  type              DiscountType
  value             Decimal      @db.Decimal(12, 2)
  maxValue          Decimal?     @db.Decimal(12, 2)
  requiresApproval  Boolean      @default(false)
  approvalThreshold Decimal?     @db.Decimal(12, 2)
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleItems SaleItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Receipt {
  id            String    @id @default(cuid())
  saleId        String    @unique
  receiptNumber String    @unique
  content       Json?
  printCount    Int       @default(0)
  printedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sale      Sale       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  printJobs PrintJob[]
}

model PrintJob {
  id              String         @id @default(cuid())
  tenantId        String
  saleId          String
  returnId        String?
  receiptId       String?
  type            PrintJobType
  status          PrintJobStatus @default(PENDING)
  html            String
  copies          Int            @default(1)
  createdByUserId String?
  printedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  return  Return?  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  receipt Receipt? @relation(fields: [receiptId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([saleId])
  @@index([returnId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// QuickBooks sync
// ─────────────────────────────────────────────────────────────

model SyncJob {
  id          String     @id @default(cuid())
  tenantId    String
  type        String
  direction   String
  entityType  String
  entityId    String?
  status      SyncStatus @default(PENDING)
  attempts    Int        @default(0)
  maxAttempts Int        @default(5)
  scheduledAt DateTime   @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  lastError   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs   SyncLog[]

  @@index([tenantId])
  @@index([status])
  @@index([entityType, entityId])
}

model SyncLog {
  id         String     @id @default(cuid())
  tenantId   String
  syncJobId  String?
  entityType String
  entityId   String?
  direction  String
  status     SyncStatus
  attempt    Int        @default(1)
  message    String?
  payload    Json?
  createdAt  DateTime   @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  syncJob SyncJob? @relation(fields: [syncJobId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([syncJobId])
  @@index([entityType, entityId])
  @@index([status])
  @@index([createdAt])
}

model QuickBooksConnection {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  realmId               String
  accessToken           String
  refreshToken          String
  tokenType             String    @default("bearer")
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  environment           String    @default("sandbox")
  isActive              Boolean   @default(true)
  connectedAt           DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model QuickBooksMapping {
  id             String    @id @default(cuid())
  tenantId       String
  entityType     String
  localId        String
  quickbooksId   String
  quickbooksType String
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entityType, localId])
  @@unique([tenantId, entityType, quickbooksId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────
// Audit
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// Returns / refunds
// ─────────────────────────────────────────────────────────────
//
// A Return is created only against an existing COMPLETED sale. All refund
// figures are recomputed on the server from the original sale snapshot — the
// client-supplied amounts are never trusted. QuickBooks stays the inventory /
// accounting source of truth: completing a return enqueues a sync job (Refund
// Receipt or Credit Memo) rather than mutating stock locally.

model Return {
  id                        String                        @id @default(cuid())
  tenantId                  String
  branchId                  String
  registerId                String?
  originalSaleId            String
  customerId                String?
  createdByUserId           String
  approvedByUserId          String?
  approvalToken             String?
  returnNumber              String
  status                    ReturnStatus                  @default(DRAFT)
  // Server-recomputed refund breakdown (all Decimal(12,2)).
  subtotal                  Decimal                       @default(0) @db.Decimal(12, 2)
  productDiscountAdjustment Decimal                       @default(0) @db.Decimal(12, 2)
  orderDiscountAdjustment   Decimal                       @default(0) @db.Decimal(12, 2)
  taxAdjustment             Decimal                       @default(0) @db.Decimal(12, 2)
  refundTotal               Decimal                       @default(0) @db.Decimal(12, 2)
  refundMethod              PaymentMethod?
  refundReference           String?
  refundStatus              RefundStatus                  @default(PENDING)
  quickbooksDocumentType    QuickBooksReturnDocumentType?
  quickbooksDocumentId      String?
  syncStatus                SyncStatus                    @default(NOT_SYNCED)
  syncError                 String?
  notes                     String?
  // Guards against a double-submitted completion creating two returns.
  idempotencyKey            String?
  completedAt               DateTime?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id])
  register       Register?       @relation(fields: [registerId], references: [id])
  originalSale   Sale            @relation(fields: [originalSaleId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id])
  createdBy      User            @relation("ReturnCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy     User?           @relation("ReturnApprovedBy", fields: [approvedByUserId], references: [id])
  items          ReturnItem[]
  refundPayments RefundPayment[]
  printJobs      PrintJob[]

  @@unique([tenantId, returnNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([branchId])
  @@index([originalSaleId])
  @@index([customerId])
  @@index([createdByUserId])
  @@index([status])
  @@index([syncStatus])
  @@index([createdAt])
}

model ReturnItem {
  id                         String           @id @default(cuid())
  returnId                   String
  originalSaleItemId         String
  productId                  String
  // Snapshots so the return survives product edits / deletes.
  productNameSnapshot        String
  skuSnapshot                String?
  imageUrlSnapshot           String?
  originalUnitPrice          Decimal          @db.Decimal(12, 2)
  purchasedQuantity          Decimal          @db.Decimal(12, 3)
  previouslyReturnedQuantity Decimal          @db.Decimal(12, 3)
  returnQuantity             Decimal          @db.Decimal(12, 3)
  returnReason               ReturnReason
  itemCondition              ItemCondition
  stockDisposition           StockDisposition
  note                       String?
  // Server-recomputed proportional reversal (all Decimal(12,2)).
  originalLineSubtotal       Decimal          @db.Decimal(12, 2)
  productDiscountAdjustment  Decimal          @default(0) @db.Decimal(12, 2)
  orderDiscountAdjustment    Decimal          @default(0) @db.Decimal(12, 2)
  taxAdjustment              Decimal          @default(0) @db.Decimal(12, 2)
  refundableAmount           Decimal          @db.Decimal(12, 2)
  createdAt                  DateTime         @default(now())

  return           Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)
  originalSaleItem SaleItem @relation(fields: [originalSaleItemId], references: [id])
  product          Product  @relation(fields: [productId], references: [id])

  @@index([returnId])
  @@index([originalSaleItemId])
  @@index([productId])
}

model RefundPayment {
  id                  String        @id @default(cuid())
  tenantId            String
  returnId            String
  processedByUserId   String?
  method              PaymentMethod
  amount              Decimal       @db.Decimal(12, 2)
  reference           String?
  // Extra structured fields used by specific methods (card terminal ref,
  // bank transfer date, store-credit expiry, drawer/register id, …).
  metadata            Json?
  quickbooksPaymentId String?
  syncStatus          SyncStatus    @default(NOT_SYNCED)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  return      Return @relation(fields: [returnId], references: [id], onDelete: Cascade)
  processedBy User?  @relation(fields: [processedByUserId], references: [id])

  @@index([tenantId])
  @@index([returnId])
  @@index([syncStatus])
}

// ─────────────────────────────────────────────────────────────
// Quotations
// ─────────────────────────────────────────────────────────────
//
// A Quotation is a non-binding priced offer. Its money is always recomputed on
// the server (client totals are never trusted). Every save produces or updates
// a QuotationRevision snapshot so the customer-facing history is preserved; the
// Quotation row mirrors the latest revision's totals for fast list rendering.

model Quotation {
  id                      String          @id @default(cuid())
  tenantId                String
  branchId                String?
  customerId              String?
  createdByUserId         String
  quotationNumber         String
  // Highest revision number that exists (0 = original draft, 1 = R1, …).
  currentRevisionNumber   Int             @default(0)
  status                  QuotationStatus @default(DRAFT)
  issueDate               DateTime        @default(now())
  validUntil              DateTime?
  // Mirror of the latest revision's server-recomputed totals (Decimal(12,2)).
  subtotal                Decimal         @default(0) @db.Decimal(12, 2)
  productDiscountTotal    Decimal         @default(0) @db.Decimal(12, 2)
  quotationDiscountType   DiscountType?
  quotationDiscountValue  Decimal?        @db.Decimal(12, 2)
  quotationDiscountAmount Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount               Decimal         @default(0) @db.Decimal(12, 2)
  grandTotal              Decimal         @default(0) @db.Decimal(12, 2)
  notes                   String?
  termsAndConditions      String?
  // Set once the quotation has been converted; guards against double-conversion.
  convertedSaleId         String?         @unique
  // Unguessable token backing the read-only public share URL.
  shareToken              String?         @unique
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?             @relation(fields: [branchId], references: [id])
  customer      Customer?           @relation(fields: [customerId], references: [id])
  createdBy     User                @relation("QuotationCreatedBy", fields: [createdByUserId], references: [id])
  convertedSale Sale?               @relation("QuotationConvertedSale", fields: [convertedSaleId], references: [id])
  revisions     QuotationRevision[]
  shareLogs     QuotationShareLog[]

  @@unique([tenantId, quotationNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([customerId])
  @@index([createdByUserId])
  @@index([status])
  @@index([validUntil])
  @@index([createdAt])
}

// One immutable snapshot of a quotation's contents. Editing a DRAFT reuses its
// current revision; creating a revision (after Sent) inserts a new one and
// bumps Quotation.currentRevisionNumber, chaining `previousRevisionId`.
model QuotationRevision {
  id                      String        @id @default(cuid())
  quotationId             String
  revisionNumber          Int
  previousRevisionId      String?       @unique
  changedByUserId         String
  changeReason            String?
  subtotal                Decimal       @default(0) @db.Decimal(12, 2)
  productDiscountTotal    Decimal       @default(0) @db.Decimal(12, 2)
  quotationDiscountType   DiscountType?
  quotationDiscountValue  Decimal?      @db.Decimal(12, 2)
  quotationDiscountAmount Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount               Decimal       @default(0) @db.Decimal(12, 2)
  grandTotal              Decimal       @default(0) @db.Decimal(12, 2)
  // Grand total of the revision this one supersedes (for old-vs-new display).
  previousGrandTotal      Decimal?      @db.Decimal(12, 2)
  notes                   String?
  termsAndConditions      String?
  validUntil              DateTime?
  createdAt               DateTime      @default(now())

  quotation        Quotation          @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  previousRevision QuotationRevision? @relation("QuotationRevisionChain", fields: [previousRevisionId], references: [id])
  nextRevision     QuotationRevision? @relation("QuotationRevisionChain")
  changedBy        User               @relation("QuotationRevisionChangedBy", fields: [changedByUserId], references: [id])
  items            QuotationItem[]

  @@unique([quotationId, revisionNumber])
  @@index([quotationId])
}

// A line on a quotation revision. Everything the document needs is snapshotted
// so the quotation renders correctly even after the product is edited/deleted.
model QuotationItem {
  id                  String        @id @default(cuid())
  quotationRevisionId String
  productId           String?
  productNameSnapshot String
  skuSnapshot         String?
  imageUrlSnapshot    String?
  descriptionSnapshot String?
  categorySnapshot    String?
  subcategorySnapshot String?
  quantity            Decimal       @db.Decimal(12, 3)
  unitType            String?
  unitPrice           Decimal       @db.Decimal(12, 2)
  discountType        DiscountType?
  discountValue       Decimal?      @db.Decimal(12, 2)
  discountAmount      Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal       @default(0) @db.Decimal(12, 2)
  lineSubtotal        Decimal       @db.Decimal(12, 2)
  lineTotal           Decimal       @db.Decimal(12, 2)
  itemNote            String?
  availabilityStatus  String?
  sortOrder           Int           @default(0)
  createdAt           DateTime      @default(now())

  revision QuotationRevision @relation(fields: [quotationRevisionId], references: [id], onDelete: Cascade)
  product  Product?          @relation(fields: [productId], references: [id])

  @@index([quotationRevisionId])
  @@index([productId])
}

// Audit trail of every time a quotation was delivered (WhatsApp / email /
// download / print). Also the hook where a future WhatsApp Business API or a
// real email provider records its per-send status + provider errors.
model QuotationShareLog {
  id                  String       @id @default(cuid())
  tenantId            String
  quotationId         String
  quotationRevisionId String?
  channel             ShareChannel
  recipient           String?
  status              ShareStatus  @default(PENDING)
  sentByUserId        String?
  errorMessage        String?
  sentAt              DateTime     @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  sentBy    User?     @relation("QuotationShareSentBy", fields: [sentByUserId], references: [id])

  @@index([tenantId])
  @@index([quotationId])
  @@index([channel])
}
