{
  "name": "@hardware-pos/api",
  "version": "0.1.0",
  "private": true,
  "description": "Hardware POS backend — NestJS API, business logic, and QuickBooks sync orchestration.",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo",
    "seed:qbo": "tsx scripts/seed-quickbooks-sandbox.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@hardware-pos/database": "workspace:*",
    "@hardware-pos/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.17.2",
    "puppeteer": "^25.3.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.17.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "eslint": "^9.17.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.63.0"
  }
}
