# Hardware POS API environment
NODE_ENV=development

# HTTP port the NestJS server listens on
API_PORT=4000

# PostgreSQL connection string (consumed via @hardware-pos/database / Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hardware_pos?schema=public"

# Allowed CORS origin for the web front-end
WEB_ORIGIN=http://localhost:3000

# ── QuickBooks Online (placeholders — integration not implemented yet) ──
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:4000/quickbooks/callback
QBO_ENVIRONMENT=sandbox
