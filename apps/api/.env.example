# Hardware POS API environment
NODE_ENV=development

# HTTP port the NestJS server listens on
API_PORT=4000

# PostgreSQL connection string (consumed via @hardware-pos/database / Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hardware_pos?schema=public"

# Allowed CORS origin for the web front-end
WEB_ORIGIN=http://localhost:3000

# Auth — secret used to sign session JWTs (required). Use a long random value.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

# ── Upload storage ──
# 'local' (default): files under <cwd>/uploads on the API server, served at /uploads.
# 's3': AWS S3 or an S3-compatible endpoint (LocalStack, MinIO). For the bundled
# LocalStack service (docker-compose): uncomment everything below as-is, then
# create the bucket once inside the container:
#   awslocal s3 mb s3://hardware-pos-uploads
# STORAGE_PROVIDER=s3
# S3_BUCKET=hardware-pos-uploads
# S3_REGION=us-east-1
# Use 127.0.0.1 (not localhost): Node resolves localhost to ::1, which rootless
# container port-forwarding accepts and then resets.
# S3_ENDPOINT=http://127.0.0.1:4566
# S3_ACCESS_KEY_ID=test
# S3_SECRET_ACCESS_KEY=test
# Lifetime of presigned S3 read URLs, in seconds (default 300 = 5 min; max 604800).
# S3_SIGNED_URL_TTL_SECONDS=300

# ── Image processing (applies to every stored image, both providers) ──
# On upload, images are downscaled to IMAGE_MAX_EDGE (longest edge, px) and
# re-encoded to WebP at IMAGE_WEBP_QUALITY. IMAGE_CACHE_MAX_AGE_SECONDS is how long
# a browser caches a served image (Cache-Control max-age). Defaults shown.
# IMAGE_MAX_EDGE=780
# IMAGE_WEBP_QUALITY=80
# IMAGE_CACHE_MAX_AGE_SECONDS=21600

# ── QuickBooks Online OAuth 2.0 ──
# Create an app at https://developer.intuit.com and copy the keys here.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:4000/v1/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# Key used to encrypt stored OAuth tokens at rest (required for QuickBooks).
TOKEN_ENCRYPTION_KEY=change-me-32-byte-random-secret

# ── Documents / A4 PDF (quotations + bills + return notes) ──
# Server-side PDF uses headless Chromium via Puppeteer. `pnpm install` downloads
# Chromium automatically (build approved in pnpm-workspace.yaml). To reuse an
# existing browser instead, point this at its binary, e.g. on macOS:
#   PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
# If neither is available, the app still serves print-ready A4 HTML (Save as PDF).
PUPPETEER_EXECUTABLE_PATH=

# Base URL for public quotation share links (…/public/quotations/:token)
PUBLIC_SHARE_BASE_URL=http://localhost:4000/v1

# ── Email sharing ──
# Provider: log | resend | smtp. `log` (default) records the email without
# sending it — no credentials needed. Switch to a real provider below.
MAIL_PROVIDER=log
MAIL_FROM=Hardware POS <no-reply@hardware-pos.local>

# Resend (https://resend.com) — verify a sending domain, create an API key:
#   MAIL_PROVIDER=resend
#   RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
#   MAIL_FROM=Quotes <quotes@yourdomain.com>
RESEND_API_KEY=

# SMTP (any provider incl. SendGrid/Mailgun/Gmail via SMTP):
#   MAIL_PROVIDER=smtp
#   SMTP_HOST=smtp.yourprovider.com
#   SMTP_PORT=587
#   SMTP_SECURE=false        # true for port 465
#   SMTP_USER=apikey-or-username
#   SMTP_PASS=your-smtp-password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
